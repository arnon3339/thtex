{
  "name": "thtex-react-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "icons": "node scripts/create-pwa-icons.mjs",
    "thtex:assets": "thtex --to public/xelatex --max-file-size 24MiB",
    "predev": "pnpm run thtex:assets",
    "dev": "vite",
    "prebuild": "pnpm run thtex:assets",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@arnon3339/thtex": "file:../.."
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  },
  "packageManager": "pnpm@11.9.0"
}
